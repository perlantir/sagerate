# Database (Supabase)
DATABASE_URL=postgresql://...
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=changeme

# reCAPTCHA v3
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Verification Services (all optional — app works without them)
REAL_PHONE_VALIDATION_API_KEY=
ZEROBOUNCE_API_KEY=
IPQUALITYSCORE_API_KEY=
SMARTY_AUTH_ID=
SMARTY_AUTH_TOKEN=

# TrustedForm (optional — embed script only if key present)
NEXT_PUBLIC_TRUSTEDFORM_SCRIPT_URL=
NEXT_PUBLIC_JORNAYA_CAMPAIGN_KEY=

# Email notifications
RESEND_API_KEY=
ADMIN_NOTIFICATION_EMAIL=

# Rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Professional mortgage rate scraping
RATE_SCRAPER_MODE=fetch_html
RATE_SCRAPER_TIMES=10:00,15:00
RATE_SCRAPER_DELAY_MS=1500
RATE_SCRAPER_HEADLESS=true
RATE_SCRAPER_PROFILE_DIR=.rate-scraper-chrome-profile
RATE_SCRAPER_CHROME_PATH=
RATE_SCRAPER_USER_AGENT=
RATE_SCRAPER_SOURCE_OVERRIDES=

# App
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_NAME=ProLoanMatch
